# === WALLET ===
# Your Base wallet address that will receive USDC payments
PAY_TO_ADDRESS=0xYourWalletAddress

# === CDP (Coinbase Developer Platform) ===
# Get these from https://portal.cdp.coinbase.com
# Required for mainnet facilitator. Optional for testnet (x402.org facilitator works without auth).
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=

# === ANTHROPIC ===
# Claude API key for the extraction intelligence layer
ANTHROPIC_API_KEY=sk-ant

# === NETWORK ===
# "base-sepolia" for testing, "base" for production
NETWORK=base-sepolia

# === METRICS ===
# Secret key for accessing GET /metrics (pass as X-Metrics-Key header)
METRICS_KEY=

# === RENDERING ===
# "true" = always use Playwright (accurate), "false" = Cheerio first with Playwright fallback (fast)
PLAYWRIGHT_ALWAYS=true

# === SERVER ===
PORT=4021
